---
# Copy this file to `.claude/mem-vault.local.md` in your project root and edit.
# Do NOT commit (already covered by `.claude/*.local.md` in .gitignore patterns;
# add that line to YOUR project's .gitignore as well).
#
# All keys are optional — anything you omit falls back to the documented default.

# Master kill switch. If false, all hooks no-op and the MCP server returns
# `{ disabled: true }` for every tool call instead of querying the DB.
enabled: true

# Auto-create a project-local `.mem-vault/` directory at the project root the
# first time the plugin fires (SessionStart hook, PostToolUse hook, MCP tool
# call from Codex, or CLI command).  The new directory holds this project's
# vault.db + meta.json — one project = one folder, no shared global slug.
#
# If a pre-existing global vault is found at ~/.mem-vault/projects/<slug>/,
# its data is transparently copied into the new local dir on first creation
# (no data loss for existing setups).
#
# Set false to keep the legacy behavior (use ~/.mem-vault/projects/<slug>/ only
# and never auto-create a project-local dir).
auto_create_project_vault: true

# ---- Capture (PostToolUse hook) ----

# Disable just the auto-capture hook (sessions still start/end normally,
# search/timeline still work on previously captured data).
capture_enabled: true

# Extra regex patterns of read-only Bash commands to skip on top of the
# built-in filter (find/grep/git status/etc). Each entry is compiled with `new RegExp(...)`.
capture_filter_extra: []

# Truncate long observation bodies to this many characters.
capture_max_body_chars: 4000

# ---- Session start indexer (SessionStart hook) ----

# Whether the SessionStart hook should emit the recent-context block at all.
session_index_enabled: true

# How many recent observations to surface in that block.
session_index_limit: 12

# ---- Prefetch hooks (forces the agent to consult mem-vault) ----

# UserPromptSubmit hook — at every turn, auto-search the vault for the user's
# prompt and inject any matching prior observations as additionalContext so
# the agent sees them BEFORE deciding to Grep/Read. This is the main lever
# that stops the agent from re-deriving things it already learned.
prefetch_on_user_prompt: true

# PreToolUse hook — before Grep/Read/Glob/Bash, surface any prior memory that
# matches what the agent is about to search for. HINT only; never blocks.
pretool_hint: true

# Cap on number of vault hits injected by either prefetch hook.
prefetch_max_results: 5

# FTS5 score threshold; 0 = include every match.
prefetch_min_score: 0

# ---- Auto-promotion (PostToolUse hook) ----

# When true, every captured Bash/Edit/Write observation is run through a
# small classifier that may upgrade its `type` from `capture`/`change` to
# `bugfix`, `feature`, `refactor`, or `discovery` based on surrounding
# context (recent test failures, new file creation, multiple consecutive
# edits to one file, stack-trace output, etc.). The original capture is
# updated in place — no duplicates are created.
auto_promote: true

# Minimum classifier confidence (0..1) required to apply a promotion.
auto_promote_min_confidence: 0.6

# ---- Periodic consolidator (background daemon) ----

# Every N minutes, the dashboard daemon scans the last
# `consolidator_window_hours` of `capture`/`change` observations across ALL
# registered projects and groups them into single high-signal summaries
# (one `refactor` per file edited >3 times, one `discovery` per
# capture+edit investigation sequence, etc.). Source observations are
# kept and tagged `consolidated_into:<id>` so they remain searchable.
# Set to 0 to disable.
consolidator_interval_min: 30
consolidator_window_hours: 24

# When true, doctor includes the last 10 user prompts and the terms the
# query extractor produced for each (debug aid).
query_extract_debug: false

# ---- Session end consolidation (SessionEnd hook) ----

# Run lightweight dedupe on session end. Default false — closing the session
# row is always safe; this controls only the optional DELETE pass.
consolidate_on_session_end: false

# ---- Dashboard ----

# Default port/host for `node server/index.js dashboard`.
# Precedence: CLI flag (--port/--host) > env var (MEM_VAULT_DASHBOARD_PORT/HOST) > this setting > built-in default.
dashboard_port: 37777
dashboard_host: 127.0.0.1

# Auto-open the system browser when the dashboard starts. `--no-open` always wins.
dashboard_open_browser: true

# Auto-start the dashboard as a 24x7 detached background daemon the first time
# ANY platform (Claude Code SessionStart hook, PostToolUse hook, MCP server
# request from CC or Codex, or the CLI) touches the plugin. The daemon
# outlives individual sessions, CC restarts, and Codex restarts. Set false to
# opt out — you can still launch the dashboard manually with
# `/mem-vault:dashboard` or `node server/index.js dashboard --foreground`.
dashboard_autostart: true

# Health endpoint exposed by the dashboard. Used by the autostart probe to
# confirm the bound process is mem-vault's dashboard (and not some other tool
# that happens to be on `dashboard_port`). Rarely needs to change.
dashboard_health_endpoint: /__memvault_health

# ---- Logging ----

# silent | info | debug — controls warnings/info written to stderr by the
# settings loader and other components.
log_verbosity: info
---

# Project-scoped notes for mem-vault

Free-form markdown below the frontmatter is ignored by the plugin but useful
for human documentation of what this project's memory contains and any manual
maintenance notes.

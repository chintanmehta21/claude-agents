{
  "description": "Code-pipeline hooks for automatic changelog generation and execution tracking",
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/execution-changelog.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}